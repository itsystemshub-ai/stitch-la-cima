APP_KEY=
APP_ENV=production
APP_DEBUG=false
APP_URL=

DB_CONNECTION=mysql   # o pgsql si usas PostgreSQL
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

