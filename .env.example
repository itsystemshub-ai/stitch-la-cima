APP_NAME="La Cima"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_VE

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================
# DESARROLLO LOCAL (SQLite)
# ============================================
DB_CONNECTION=sqlite

# ============================================
# PRODUCCIÓN (MySQL) - Descomenta y configura
# ============================================
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=lacima
# DB_USERNAME=lacima_user
# DB_PASSWORD=tu_contraseña_segura

# ============================================
# PRODUCCIÓN (PostgreSQL) - Alternativa
# ============================================
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=lacima
# DB_USERNAME=lacima_user
# DB_PASSWORD=tu_contraseña_segura

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_STORE=redis

# ============================================
# EMAIL ( SMTP )
