// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Hybrid Database Configuration
// Local Development: SQLite
// Production (Cloud): PostgreSQL

// Detect environment automatically via DATABASE_URL
// SQLite: file:./dev.db
// PostgreSQL: postgresql://user:pass@host:port/db

datasource db {
  provider = env("DB_PROVIDER")
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique @db.VarChar(255)
  name      String?  @db.VarChar(255)
  password  String   @db.VarChar(255)
  role      String   @default("USER") // ADMIN, MANAGER, EMPLOYEE, USER
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  sales     Sale[]

  @@map("users")
}

model Product {
  id          Int      @id @default(autoincrement())
  sku         String   @unique @db.VarChar(50)
  name        String   @db.VarChar(255)
  description String?  @db.Text
  price       Float
  stock       Int      @default(0)
  category    String?  @db.VarChar(100)
  brand       String?  @db.VarChar(100)
  origin      String?  @db.VarChar(100)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  inventoryLogs InventoryLog[]
  saleItems     SaleItem[]

  @@index([category])
  @@index([brand])
  @@index([sku])
  @@map("products")
}

model InventoryLog {
  id        Int      @id @default(autoincrement())
  productId Int      @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      String   @db.VarChar(10)   // IN, OUT, ADJUST
  quantity  Int
  cost      Float
  reason    String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@index([createdAt])
  @@map("inventory_logs")
}

model Sale {
  id                Int        @id @default(autoincrement())
  userId            Int?       @map("user_id")
  user              User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  invoiceNumber     String?    @unique @map("invoice_number") @db.VarChar(50)
  subtotal          Float      @default(0)
  tax               Float      @default(0)
  discount          Float      @default(0)
  paymentReference  String?    @map("payment_reference") @db.VarChar(100)
  total             Float
  status            String     @default("COMPLETED") @db.VarChar(20) // PENDING, COMPLETED, CANCELLED
  paymentMethod     String     @map("payment_method") @db.VarChar(50)
  createdAt         DateTime   @default(now()) @map("created_at")
  items             SaleItem[]
  creditNotes       CreditNote[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([invoiceNumber])
  @@map("sales")
}

model CreditNote {
  id                 Int      @id @default(autoincrement())
  creditNoteNumber   String   @unique @map("credit_note_number") @db.VarChar(50)
  saleId             Int      @map("sale_id")
  sale               Sale     @relation(fields: [saleId], references: [id], onDelete: Restrict)
  userId             Int      @map("user_id")
  amount             Float
  reason             String?  @db.Text
  status             String   @default("ISSUED") @db.VarChar(20) // ISSUED, APPLIED, CANCELLED
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([saleId])
  @@index([userId])
  @@index([createdAt])
  @@map("credit_notes")
}

model SaleItem {
  id        Int     @id @default(autoincrement())
  saleId    Int     @map("sale_id")
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId Int     @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Int
  price     Float

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

model Employee {
  id          Int      @id @default(autoincrement())
  firstName   String   @map("first_name") @db.VarChar(100)
  lastName    String   @map("last_name") @db.VarChar(100)
  dni         String   @unique @map("dni") @db.VarChar(20)
  email       String   @unique @db.VarChar(255)
  position    String   @db.VarChar(100)
  department  String   @db.VarChar(100)
  hireDate    DateTime @map("hire_date")
  salary      Float
  active      Boolean  @default(true)
  payroll     Payroll[]

  @@index([department])
  @@index([dni])
  @@map("employees")
}

model Payroll {
  id          Int      @id @default(autoincrement())
  employeeId  Int      @map("employee_id")
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  month       Int
  year        Int
  baseSalary  Float    @map("base_salary")
  bonuses     Float    @default(0)
  deductions  Float    @default(0) @map("deductions")
  netSalary   Float    @map("net_salary")
  processed   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([employeeId])
  @@index([year, month])
  @@map("payrolls")
}

model Attendance {
  id          Int      @id @default(autoincrement())
  employeeId  Int      @map("employee_id")
  date        DateTime @db.Date
  checkIn     DateTime @map("check_in")
  checkOut    DateTime? @map("check_out")
  hours       Float?
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@map("attendance")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  icon        String?   @db.VarChar(50)
  description String?   @db.Text
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([name])
  @@map("categories")
}

model Supplier {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  rif         String   @unique @db.VarChar(20)  // Tax ID (Venezuela)
  email       String?  @db.VarChar(255)
  phone       String?  @db.VarChar(20)
  address     String?  @db.Text
  contact     String?  @db.VarChar(255)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  purchases   PurchaseOrder[]

  @@index([rif])
  @@index([name])
  @@map("suppliers")
}

model PurchaseOrder {
  id          Int      @id @default(autoincrement())
  number      String   @unique @db.VarChar(20)  // PO number
  supplierId  Int      @map("supplier_id")
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  total       Float
  status      String   @default("PENDING") @db.VarChar(20) // PENDING, APPROVED, RECEIVED, CANCELLED
  orderDate   DateTime @map("order_date")
  receivedAt  DateTime? @map("received_at")
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  items       PurchaseItem[]

  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
  @@map("purchase_orders")
}

model PurchaseItem {
  id              Int           @id @default(autoincrement())
  purchaseOrderId Int           @map("purchase_order_id")
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       Int?
  productName     String        @db.VarChar(255)
  sku             String?       @db.VarChar(50)
  quantity        Int
  unitCost        Float         @map("unit_cost")
  total           Float
  received        Int           @default(0)

  @@index([purchaseOrderId])
  @@map("purchase_items")
}

// ============================================================
// Accounting & Finance Models
// ============================================================

model Account {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(20)  // Account code (e.g., "1.01.01")
  name        String   @db.VarChar(255)
  type        String   @db.VarChar(20)  // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  parentCode  String?  @map("parent_code") @db.VarChar(20)
  balance     Float    @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  journalEntries JournalEntryLine[]

  @@index([type])
  @@index([code])
  @@map("accounts")
}

model JournalEntry {
  id          Int      @id @default(autoincrement())
  number      String   @unique @db.VarChar(20)  // Entry number
  date        DateTime @db.Date
  description String   @db.Text
  totalDebit  Float    @default(0) @map("total_debit")
  totalCredit Float    @default(0) @map("total_credit")
  posted      Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  lines       JournalEntryLine[]

  @@index([date])
  @@index([posted])
  @@map("journal_entries")
}

model JournalEntryLine {
  id              Int            @id @default(autoincrement())
  entryId         Int            @map("entry_id")
  entry           JournalEntry   @relation(fields: [entryId], references: [id], onDelete: Cascade)
  accountId       Int            @map("account_id")
  account         Account        @relation(fields: [accountId], references: [id])
  debit           Float          @default(0)
  credit          Float          @default(0)
  description     String?        @db.Text

  @@index([entryId])
  @@index([accountId])
  @@map("journal_entry_lines")
}

model FixedAsset {
  id              Int      @id @default(autoincrement())
  name            String   @db.VarChar(255)
  code            String   @unique @db.VarChar(20)
  category        String   @db.VarChar(100)
  acquisitionDate DateTime @map("acquisition_date") @db.Date
  acquisitionCost Float    @map("acquisition_cost")
  usefulLife      Int      @map("useful_life")  // years
  depreciationMethod String @default("STRAIGHT_LINE") @map("depreciation_method") @db.VarChar(20) // STRAIGHT_LINE, DECLINING
  salvageValue    Float    @default(0) @map("salvage_value")
  currentBookValue Float   @map("current_book_value")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("fixed_assets")
}

model AccountsReceivable {
  id          Int      @id @default(autoincrement())
  customerId  String   @map("customer_id") @db.VarChar(50)
  customerName String  @map("customer_name") @db.VarChar(255)
  saleId      Int?
  invoiceNumber String @map("invoice_number") @db.VarChar(20)
  amount      Float
  paidAmount  Float    @default(0) @map("paid_amount")
  dueDate     DateTime @map("due_date") @db.Date
  status      String   @default("PENDING") @db.VarChar(20) // PENDING, PARTIAL, PAID, OVERDUE
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@map("accounts_receivable")
}

model SystemConfig {
  id          Int      @id @default(autoincrement())
  key         String   @unique @db.VarChar(100)
  value       String   @db.Text
  description String?  @db.Text
  category    String   @db.VarChar(50)  // GENERAL, FISCAL, INVENTORY, SALES, HR
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("system_configs")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String   @db.VarChar(100)  // LOGIN, CREATE, UPDATE, DELETE, APPROVE, CANCEL
  entity    String   @db.VarChar(50)   // Entity type (User, Product, Sale, etc.)
  entityId  String?  @map("entity_id") @db.VarChar(50)
  details   String?  @db.Text         // JSON with old/new values
  ip        String?  @db.VarChar(45)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Backup {
  id          Int      @id @default(autoincrement())
  filename    String   @db.VarChar(255)
  size        Int
  status      String   @default("PENDING") @db.VarChar(20) // PENDING, COMPLETED, FAILED
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  @@index([status])
  @@index([createdAt])
  @@map("backups")
}
