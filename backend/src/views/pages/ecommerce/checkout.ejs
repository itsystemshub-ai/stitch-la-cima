<div class="max-w-4xl mx-auto px-6 py-10">
  <h1 class="text-3xl font-extrabold text-black mb-8">Checkout y Facturación</h1>
  
  <% if (cartItems && cartItems.length > 0) { %>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2">
        <div class="bg-white rounded-xl shadow-card p-6">
          <h2 class="font-bold text-lg mb-4">Detalles de Facturación</h2>
          <form class="space-y-4">
            <input type="text" placeholder="Dirección" class="w-full bg-stone-100 border-none rounded-lg px-4 py-3 text-sm"/>
            <input type="text" placeholder="RIF" class="w-full bg-stone-100 border-none rounded-lg px-4 py-3 text-sm"/>
            <select class="w-full bg-stone-100 border-none rounded-lg px-4 py-3 text-sm">
              <option>Transferencia B2B</option>
              <option>Crédito Corporativo</option>
              <option>Tarjeta de Crédito</option>
            </select>
          </form>
        </div>
      </div>
      
      <div class="bg-white rounded-xl shadow-card p-6 h-fit">
        <h2 class="font-bold text-lg mb-4">Resumen</h2>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between"><span>Subtotal</span><span>$<%= subtotal.toFixed(2) %></span></div>
          <div class="flex justify-between"><span>IVA 16%</span><span>$<%= tax.toFixed(2) %></span></div>
          <div class="flex justify-between"><span>Envío</span><span>$<%= shipping.toFixed(2) %></span></div>
          <div class="border-t pt-2 font-bold text-lg flex justify-between"><span>Total</span><span>$<%= total.toFixed(2) %></span></div>
        </div>
      </div>
    </div>
  <% } else { %>
    <p class="text-stone-500 text-center">Carrito vacío</p>
  <% } %>
</div>
