<div class="max-w-7xl mx-auto px-6 py-10">
  <h1 class="text-3xl font-extrabold text-black mb-2"><%= title %></h1>
  <p class="text-stone-500 mb-8"><%= totalResults %> resultados para "<%= query %>"</p>

  <% if (products && products.length > 0) { %>
    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6">
      <% products.forEach(function(product) { %>
        <a href="/producto/<%= product.id %>" class="bg-white rounded-xl shadow-card overflow-hidden hover:shadow-card-hover transition-shadow block">
          <div class="h-40 bg-stone-100 flex items-center justify-center">
            <% if (product.image) { %>
              <img src="<%= product.image %>" class="w-full h-full object-cover"/>
            <% } else { %>
              <span class="material-symbols-outlined text-5xl text-stone-300">inventory_2</span>
            <% } %>
          </div>
          <div class="p-4">
            <h3 class="font-bold text-sm text-black"><%= product.name %></h3>
            <div class="text-lg font-extrabold text-black mt-2">$<%= product.price.toFixed(2) %></div>
          </div>
        </a>
      <% }); %>
    </div>
  <% } else { %>
    <div class="text-center py-20">
      <span class="material-symbols-outlined text-6xl text-stone-300 mb-4">search_off</span>
      <p class="text-stone-500">No hay resultados. Intenta con otro término.</p>
    </div>
  <% } %>
</div>
