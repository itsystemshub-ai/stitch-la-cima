<div class="max-w-4xl mx-auto px-6 py-10">
  <h1 class="text-3xl font-extrabold text-black mb-8">Carrito de Compras</h1>
  
  <% if (cartItems && cartItems.length > 0) { %>
    <div class="bg-white rounded-xl shadow-card overflow-hidden">
      <% cartItems.forEach(function(item) { %>
        <div class="flex items-center gap-4 p-4 border-b border-outline">
          <div class="w-20 h-20 bg-stone-100 rounded-lg flex items-center justify-center">
            <span class="material-symbols-outlined text-3xl text-stone-300">inventory_2</span>
          </div>
          <div class="flex-1">
            <h3 class="font-bold text-sm"><%= item.name %></h3>
            <p class="text-xs text-stone-500"><%= item.sku %></p>
          </div>
          <div class="text-right">
            <div class="font-bold">$<%= (item.price * item.qty).toFixed(2) %></div>
            <div class="text-xs text-stone-500">x<%= item.qty %></div>
          </div>
        </div>
      <% }); %>
      
      <div class="p-6">
        <a href="/checkout" class="block w-full bg-primary text-black font-bold text-center py-3 rounded-lg uppercase tracking-wider hover:bg-primary-dim transition-colors">
          Proceder al Checkout
        </a>
      </div>
    </div>
  <% } else { %>
    <div class="text-center py-20">
      <span class="material-symbols-outlined text-6xl text-stone-300 mb-4">shopping_cart</span>
      <p class="text-stone-500 mb-4">Tu carrito está vacío</p>
      <a href="/catalogo" class="inline-block bg-primary text-black font-bold px-6 py-3 rounded-lg uppercase text-sm">Ir al Catálogo</a>
    </div>
  <% } %>
</div>
