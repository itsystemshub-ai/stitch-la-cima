<div class="flex min-h-screen bg-surface-dim">
  <!-- Sidebar -->
  <aside class="w-64 bg-secondary text-white flex-shrink-0">
    <div class="p-6">
      <h1 class="text-2xl font-extrabold italic">Zenith <span class="text-primary">ERP</span></h1>
    </div>
    <nav class="px-4 space-y-1">
      <a href="/dashboard" class="flex items-center gap-3 px-4 py-3 bg-primary/20 text-primary rounded-lg">
        <span class="material-symbols-outlined">dashboard</span>
        <span class="text-sm font-bold">Dashboard</span>
      </a>
      <a href="/erp/productos" class="flex items-center gap-3 px-4 py-3 text-stone-400 hover:bg-white/5 rounded-lg transition-colors">
        <span class="material-symbols-outlined">inventory_2</span>
        <span class="text-sm">Inventario</span>
      </a>
      <a href="/erp/ordenes" class="flex items-center gap-3 px-4 py-3 text-stone-400 hover:bg-white/5 rounded-lg transition-colors">
        <span class="material-symbols-outlined">receipt_long</span>
        <span class="text-sm">Órdenes</span>
      </a>
      <a href="/catalogo" class="flex items-center gap-3 px-4 py-3 text-stone-400 hover:bg-white/5 rounded-lg transition-colors">
        <span class="material-symbols-outlined">storefront</span>
        <span class="text-sm">Ver Tienda</span>
      </a>
    </nav>
  </aside>

  <!-- Main Content -->
  <main class="flex-1 p-8">
    <!-- Welcome Banner -->
    <div class="bg-gradient-to-r from-primary to-primary-dim rounded-2xl p-8 mb-8 text-black">
      <h2 class="text-3xl font-extrabold mb-2">Hola, <%= user.name %></h2>
      <p class="text-primary/80">Panel de Administración ERP</p>
    </div>

    <!-- KPI Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
      <div class="bg-white rounded-xl p-6 shadow-card">
        <div class="flex items-center justify-between mb-4">
          <span class="material-symbols-outlined text-3xl text-primary">inventory_2</span>
        </div>
        <div class="text-3xl font-extrabold text-black"><%= kpis.totalProducts %></div>
        <div class="text-xs text-stone-500 uppercase tracking-wider mt-1">Total SKUs</div>
      </div>

      <div class="bg-white rounded-xl p-6 shadow-card">
        <div class="flex items-center justify-between mb-4">
          <span class="material-symbols-outlined text-3xl text-warning">trending_up</span>
        </div>
        <div class="text-3xl font-extrabold text-black">$<%= kpis.monthlySales %></div>
        <div class="text-xs text-stone-500 uppercase tracking-wider mt-1">Ventas del Mes</div>
      </div>

      <div class="bg-white rounded-xl p-6 shadow-card">
        <div class="flex items-center justify-between mb-4">
          <span class="material-symbols-outlined text-3xl text-info">shopping_cart</span>
        </div>
        <div class="text-3xl font-extrabold text-black"><%= kpis.todayOrders %></div>
        <div class="text-xs text-stone-500 uppercase tracking-wider mt-1">Pedidos Hoy</div>
      </div>

      <div class="bg-white rounded-xl p-6 shadow-card">
        <div class="flex items-center justify-between mb-4">
          <span class="material-symbols-outlined text-3xl text-error">warning</span>
        </div>
        <div class="text-3xl font-extrabold text-black"><%= kpis.lowStock %></div>
        <div class="text-xs text-stone-500 uppercase tracking-wider mt-1">Stock Bajo</div>
      </div>
    </div>

    <!-- Recent Orders -->
    <div class="bg-white rounded-xl shadow-card">
      <div class="px-6 py-4 border-b border-outline">
        <h3 class="font-bold text-lg">Órdenes Recientes</h3>
      </div>
      
      <% if (recentOrders && recentOrders.length > 0) { %>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-stone-50">
              <tr>
                <th class="text-left px-6 py-3 font-bold text-stone-500">Nº Orden</th>
                <th class="text-left px-6 py-3 font-bold text-stone-500">Cliente</th>
                <th class="text-left px-6 py-3 font-bold text-stone-500">Total</th>
                <th class="text-left px-6 py-3 font-bold text-stone-500">Estado</th>
                <th class="text-left px-6 py-3 font-bold text-stone-500">Fecha</th>
              </tr>
            </thead>
            <tbody>
              <% recentOrders.forEach(function(order) { %>
                <tr class="border-b border-outline hover:bg-stone-50 transition-colors">
                  <td class="px-6 py-4 font-bold"><%= order.orderNumber %></td>
                  <td class="px-6 py-4"><%= order.user?.name || 'N/A' %></td>
                  <td class="px-6 py-4 font-bold">$<%= parseFloat(order.total).toFixed(2) %></td>
                  <td class="px-6 py-4">
                    <span class="px-2 py-1 rounded-full text-[10px] font-bold uppercase
                      <%= order.status === 'pending' ? 'bg-yellow-100 text-yellow-800' : '' %>
                      <%= order.status === 'confirmed' ? 'bg-blue-100 text-blue-800' : '' %>
                      <%= order.status === 'processing' ? 'bg-purple-100 text-purple-800' : '' %>
                      <%= order.status === 'delivered' ? 'bg-green-100 text-green-800' : '' %>
                      <%= order.status === 'cancelled' ? 'bg-red-100 text-red-800' : '' %>
                    ">
                      <%= order.status %>
                    </span>
                  </td>
                  <td class="px-6 py-4 text-stone-500"><%= new Date(order.createdAt).toLocaleDateString('es-VE') %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="p-12 text-center text-stone-500">
          <span class="material-symbols-outlined text-4xl text-stone-300 mb-4">receipt_long</span>
          <p>No hay órdenes registradas aún</p>
        </div>
      <% } %>
    </div>
  </main>
</div>

<script>
// Real-time updates via Socket.IO
if (window.socket) {
  window.socket.on('order:new', (order) => {
    showToast(`📦 Nueva orden: ${order.orderNumber}`, 'success');
    // Reload page to show new order
    setTimeout(() => location.reload(), 2000);
  });

  window.socket.on('stock:low', (data) => {
    showToast(`⚠️ Stock bajo: ${data.productName} (${data.stock} uds)`, 'warning');
  });
}
</script>
