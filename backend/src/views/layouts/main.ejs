<!DOCTYPE html>
<html class="light" lang="es">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= typeof title !== 'undefined' ? title : 'La Cima, C.A' %> | Mayor de Repuesto La Cima</title>
  <script id="tailwind-config">window.tailwind = { config: { darkMode: "class", theme: { extend: { colors: { primary: { DEFAULT: "#2545BF", dim: "#1a3599", light: "#3b5fd4" }, secondary: { DEFAULT: "#00D0D0", light: "#00FFFF" }, accent: { DEFAULT: "#00FF00" }, background: "#f5f7fa", surface: "#ffffff", "on-surface": "#222222", outline: "#d1d7e0" }, fontFamily: { sans: ["League Spartan", "sans-serif"] } } } };</script>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <link href="/css/styles.css" rel="stylesheet"/>
</head>
<body class="bg-background text-on-surface selection:bg-primary/10">
  <!-- NAVBAR -->
  <nav class="fixed top-0 w-full z-50 bg-white/95 backdrop-blur-md border-b border-outline shadow-sm">
    <div class="max-w-7xl mx-auto px-6 py-3 flex justify-between items-center">
      <div class="flex items-center gap-3">
        <img src="/assets/images/logo.png" alt="Logo" class="h-10 w-auto"/>
        <div class="hidden sm:block text-[10px] leading-tight">
          <p class="font-bold text-stone-800 tracking-wide">MAYOR DE REPUESTO LA CIMA, C.A</p>
          <p class="text-stone-500">RIF: J-40308741-5</p>
        </div>
      </div>
      <div class="hidden md:flex items-center gap-6">
        <a href="/" class="text-xs uppercase tracking-widest font-bold <%= typeof page !== 'undefined' && page === 'home' ? 'text-primary border-b-2 border-primary' : 'text-on-surface-variant hover:text-primary' %> transition-colors">Inicio</a>
        <a href="/Catalogo_general.html" class="text-xs uppercase tracking-widest font-bold text-on-surface-variant hover:text-primary transition-colors">Catálogo</a>
        <a href="/nosotros.html" class="text-xs uppercase tracking-widest font-bold text-on-surface-variant hover:text-primary transition-colors">Nosotros</a>
        <a href="/contacto.html" class="text-xs uppercase tracking-widest font-bold text-on-surface-variant hover:text-primary transition-colors">Contacto</a>
      </div>
      <div class="flex items-center gap-3">
        <% if (typeof user !== 'undefined' && user) { %>
          <a href="/carrito_de_compras.html" class="relative p-2 hover:bg-stone-100 rounded-full">
            <span class="material-symbols-outlined">shopping_cart</span>
            <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
              <span class="absolute -top-1 -right-1 bg-primary text-white text-[10px] font-bold h-4 w-4 flex items-center justify-center rounded-full"><%= cartCount %></span>
            <% } %>
          </a>
          <div class="flex items-center gap-2 bg-primary/10 px-3 py-1.5 rounded-full">
            <span class="material-symbols-outlined text-primary text-sm">person</span>
            <span class="text-[10px] font-bold text-primary uppercase"><%= user.name.split(' ')[0] %></span>
          </div>
          <% if (user.role === 'admin') { %>
            <a href="/dashboard.html" class="p-2 hover:bg-stone-100 rounded-full"><span class="material-symbols-outlined text-sm">dashboard</span></a>
          <% } %>
        <% } else { %>
          <a href="/login.html" class="flex items-center gap-2 bg-primary text-white px-4 py-2 rounded-lg hover:bg-primary-dim transition-colors uppercase text-xs font-bold">
            <span class="material-symbols-outlined text-sm">login</span>
            Ingresar
          </a>
        <% } %>
      </div>
    </div>
  </nav>

  <main class="min-h-screen pt-16">
    <%- body %>
  </main>

  <!-- FOOTER -->
  <footer class="bg-stone-900 text-white mt-20">
    <div class="max-w-7xl mx-auto px-6 py-16">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
        <div>
          <img src="/assets/images/logo.png" alt="Logo" class="h-12 w-auto mb-4 brightness-200"/>
          <p class="text-stone-400 text-sm">Distribuidor mayorista de repuestos automotrices desde 1990.</p>
        </div>
        <div>
          <h4 class="font-bold mb-4 text-primary">Navegación</h4>
          <ul class="space-y-2 text-sm text-stone-400">
            <li><a href="/" class="hover:text-white transition-colors">Inicio</a></li>
            <li><a href="/Catalogo_general.html" class="hover:text-white transition-colors">Catálogo</a></li>
            <li><a href="/nosotros.html" class="hover:text-white transition-colors">Nosotros</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold mb-4 text-primary">Legal</h4>
          <ul class="space-y-2 text-sm text-stone-400">
            <li><a href="/terminos.html" class="hover:text-white transition-colors">Términos</a></li>
            <li><a href="/privacidad.html" class="hover:text-white transition-colors">Privacidad</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold mb-4 text-primary">Contacto</h4>
          <ul class="space-y-2 text-sm text-stone-400">
            <li>Valencia, Venezuela</li>
            <li>RIF: J-40308741-5</li>
          </ul>
        </div>
      </div>
      <div class="border-t border-stone-700 mt-10 pt-6 text-center text-sm text-stone-500">
        © <%= new Date().getFullYear() %> Mayor de Repuesto La Cima, C.A. Todos los derechos reservados.
      </div>
    </div>
  </footer>

  <!-- Socket.IO -->
  <script src="/socket.io/socket.io.js"></script>
  <script>
    const socket = io();
    <% if (typeof user !== 'undefined' && user) { %>
    socket.emit('join', '<%= user.id %>');
    <% } %>
  </script>
</body>
</html>
